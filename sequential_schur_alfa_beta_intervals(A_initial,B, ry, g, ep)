def sequential_schur_alfa_beta_intervals(A_initial,B, ry, g, ep):
    # Calculate upper bounds
    u11, u22, _, _ = sequential_up_bounds_alfa_beta(A_initial, B, ry, g, ep)

    # Calculate lower bounds
    l11, l22, _, _ = sequential_low_bounds_alfa_beta(A_initial, B, ry, g, ep)

    return (l11, u11), (l22, u22)
