def pr_low_bound(A, B, ry, wy):
    n = A.shape[0] ; b = LA.norm(B, 2)
    i = 0 ; l = 0
    while True:
        i = i + 1
        Q = np.eye(n) ;  H = linalg.solve_discrete_lyapunov(A, Q)
        if not np.all(np.linalg.eigvals(H) > 0):
            print("could not be computed.")
            break
        h = LA.norm(H, 2) ; a = LA.norm(A, 2)
        r=(-a/b)+math.sqrt(a**2-(1/wy)+(1/h))/b
        if r < ry:
            break
        A = A - r * B ;  l = l - r
    return l
