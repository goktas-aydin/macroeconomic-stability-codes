def ex_up_bound(A, B, ry, g):
    n = A.shape[0] ; b = LA.norm(B, 2)
    i = 0 ; u = 0
    while True:
        i = i + 1
        Q = np.eye(n) ;  H = linalg.solve_discrete_lyapunov(A, Q)
        if not np.all(np.linalg.eigvals(H) > 0):
            print("hesaplanamadı")
            break
        h = LA.norm(H, 2) ; a = LA.norm(A, 2)
        z = (-a / b) + math.sqrt(a**2 + (1 / h)) / b ;  r = z * g
        if r < ry: break
        A = A + r * B ;  u = u + r ;
    return  u
