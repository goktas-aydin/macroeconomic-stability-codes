import numpy as np; from scipy import linalg; from numpy import linalg as LA; import math
def schur_interval(A, B, ry, g):
    n = A.shape[0] ; b = LA.norm(B, 2)

    def find_bound(direction):
        total_r = 0 ; A_copy = A.copy()
        while True:
            Q = np.eye(n) ; H = linalg.solve_discrete_lyapunov(A_copy, Q)
            if np.all(np.linalg.eigvals(H) > 0):
                h = LA.norm(H, 2) ; a = LA.norm(A_copy, 2)
                z = (-a / b) + math.sqrt(a**2 + (1 / h)) / b ; r = z * g
                if r < ry: break
                A_copy = A_copy + (r * B if direction == 'upper' else -r * B)
                total_r = total_r + (r if direction == 'upper' else -r)
            else:
                return "The matrix A is not Schur stable."
        return float(total_r)

    upper_bound = find_bound('upper')
    lower_bound = find_bound('lower')
    return (lower_bound, upper_bound)
